  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 0
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'A long time ago, five elemental gods maintained balance in the realm.



    QUAZIADORE



    When
    humanity began harnessing elemental magic for its own gain,

    the gods turned
    against each other.


    The world shattered into five floating islands,

    each
    corrupted by a different element:


    Earth.  Fire.  Water.  Air.  Aether.



    Now
    the realm teeters on the edge of total collapse.



    One soul has been chosen.


    Alex.


    Chosen
    to restore balance by reclaiming the corrupted elemental cores

    scattered
    across the islands.



    The journey begins here,

    in the Cracked Forest.


    The
    first core awaits.






'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: cc31e7808811e324699484bc54b8b284, type: 2}
